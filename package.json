{
  "name": "code-doctrine",
  "version": "0.1.2",
  "description": "CLI package manager for decentralized code doctrine packages",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "code-doctrine",
    "agents",
    "skills",
    "decentralized",
    "package-manager",
    "cli"
  ],
  "bin": {
    "code-doctrine": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "lib",
    "README.md",
    "STANDARD.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "check": "node --check cli.mjs && find lib -name '*.mjs' -print0 | xargs -0 -n1 node --check"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-doctrine/cli.git"
  },
  "homepage": "https://github.com/code-doctrine/cli",
  "bugs": {
    "url": "https://github.com/code-doctrine/cli/issues"
  }
}
